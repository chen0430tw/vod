*_result.json
*_result.txt
*_validation_report.md

# ----- Allow exceptions: Phase 1 interface drafts must be tracked -----
!model_index.json
!modular_model_index.json

# ----- Allow paper baseline artefacts (small PNG samples, JSON, MD) -----
# Three published baselines are referenced in docs/paper_v16_baseline.md
# and need to ship with the repo; their PNG samples are <100KB each.
# Trained .pt checkpoints stay ignored — mirror on nano5.
!baseline_v16/
!baseline_v16/**
!baseline_rgb64_conv/
!baseline_rgb64_conv/**
!baseline_rgb64_cond/
!baseline_rgb64_cond/**
baseline_v16/v16_ckpt.pt
baseline_rgb64_conv/*.pt
baseline_rgb64_cond/*.pt

# ----- HVBD/HVBDT raw PNGs are paper-grade source artifacts -----
# Cells under data/hvbd_static/cells/ are DERIVED (run split script).
!data/hvbd_static/
!data/hvbd_static/raw/
!data/hvbd_static/raw/**
!data/hvbd_static/metadata_schema.json
!data/hvbd_static/metadata.jsonl
!data/hvbd_static/registry.jsonl
!data/hvbdt/
!data/hvbdt/sheets/
!data/hvbdt/sheets/**
!data/hvbdt/registry.jsonl
data/hvbd_static/cells/
data/hvbdt/clips/
!configs/
!configs/*.yaml
!configs/*.json
!experiments/
!experiments/**
!reports/
!reports/**
